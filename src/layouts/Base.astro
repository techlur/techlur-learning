---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Community-driven web development interview prep.' } = Astro.props;
const sections = [
  { id: 'backend', label: 'Backend' },
  { id: 'frontend', label: 'Frontend' },
  { id: 'database', label: 'Database' },
  { id: 'ai', label: 'AI & LLMs' },
  { id: 'general', label: 'General & HR' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Spline+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-head">
      <a href="/" class="brand">
        <span class="brand-mark">{`{ }`}</span>
        <span>Fresher Interview Prep</span>
      </a>
      <nav class="site-nav">
        {sections.map((s) => <a href={`/${s.id}`}>{s.label}</a>)}
        <a class="gh" href="https://github.com/your-username/fresher-interview-prep" target="_blank" rel="noopener">
          ★ Contribute
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <p>
        Open-source &middot; add a question by opening a PR with a Markdown file.
        See <a href="https://github.com/your-username/fresher-interview-prep/blob/main/CONTRIBUTING.md">CONTRIBUTING.md</a>.
      </p>
    </footer>

    <style is:global>
      :root {
        --ink: #1a1410;
        --paper: #faf6ef;
        --paper2: #f3ecdf;
        --rust: #b5462a;
        --rust-dk: #8f3014;
        --teal: #1f6f63;
        --gold: #c8932a;
        --line: #ddd1bd;
        --shadow: 0 1px 0 rgba(0, 0, 0, 0.04), 0 8px 28px -18px rgba(60, 40, 20, 0.5);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Spline Sans', system-ui, sans-serif;
        background: var(--paper);
        color: var(--ink);
        line-height: 1.62;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--rust-dk); }

      .site-head {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 14px;
        padding: 18px 22px;
        background: var(--ink); color: var(--paper);
        border-bottom: 4px solid var(--rust);
        position: sticky; top: 0; z-index: 20;
      }
      .brand {
        display: flex; align-items: center; gap: 10px;
        color: var(--paper); text-decoration: none;
        font-family: 'Fraunces', serif; font-weight: 900; font-size: 20px;
      }
      .brand-mark {
        font-family: 'JetBrains Mono', monospace; color: var(--gold);
        font-weight: 700;
      }
      .site-nav { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
      .site-nav a {
        color: rgba(250, 246, 239, 0.85); text-decoration: none;
        font-size: 14px; padding: 7px 12px; border-radius: 8px;
        transition: 0.15s;
      }
      .site-nav a:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }
      .site-nav a.gh {
        border: 1px solid rgba(255, 255, 255, 0.25);
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
        color: var(--gold);
      }
      .site-nav a.gh:hover { background: var(--rust); color: #fff; border-color: var(--rust); }

      main { max-width: 900px; margin: 0 auto; padding: 0 22px 60px; }

      .site-foot {
        background: var(--ink); color: rgba(250, 246, 239, 0.7);
        text-align: center; padding: 32px 22px; font-size: 14px;
        border-top: 4px solid var(--gold);
      }
      .site-foot a { color: var(--gold); }

      /* shared code styling for rendered markdown */
      pre {
        background: #241d17; color: #f0e7d8; border-radius: 10px;
        padding: 16px 18px; overflow-x: auto; margin: 14px 0;
        font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 1.6;
      }
      :not(pre) > code {
        font-family: 'JetBrains Mono', monospace; font-size: 0.88em;
        background: var(--paper2); border: 1px solid var(--line);
        padding: 1px 6px; border-radius: 5px; color: var(--rust-dk);
      }
      blockquote {
        border-left: 4px solid var(--teal);
        background: #eaf4f1; padding: 12px 16px; border-radius: 0 10px 10px 0;
        margin: 14px 0; font-size: 0.95em;
      }
    </style>
  </body>
</html>
