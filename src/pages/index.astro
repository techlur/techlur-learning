---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const all = await getCollection('questions');

const sections = [
  { id: 'backend', label: 'Backend', desc: 'HTTP, Node, NestJS, auth, APIs' },
  { id: 'frontend', label: 'Frontend', desc: 'JavaScript, React, CSS, the web' },
  { id: 'database', label: 'Database', desc: 'MySQL, SQL, modelling, indexing' },
  { id: 'ai', label: 'AI & LLMs', desc: 'Concepts, RAG, APIs, prompting' },
  { id: 'general', label: 'General & HR', desc: 'Git, DSA, OOP, behavioural' },
].map((s) => ({
  ...s,
  count: all.filter((q) => q.data.section === s.id).length,
}));

const total = all.length;
---

<Base title="Fresher Interview Prep — Web Development">
  <section class="hero">
    <p class="eyebrow">// open-source · community-driven</p>
    <h1>The Fresher's <em>Interview</em> Playbook</h1>
    <p class="sub">
      A community-built bank of web development interview questions with model
      answers — for Node.js / NestJS · React · MySQL aspirants. Add yours via a
      Markdown pull request.
    </p>
    <p class="stat"><strong>{total}</strong> questions and growing</p>
  </section>

  <div class="grid">
    {sections.map((s) => (
      <a href={`/${s.id}`} class="card">
        <span class="count">{s.count} Q</span>
        <h2>{s.label}</h2>
        <p>{s.desc}</p>
        <span class="go">Browse →</span>
      </a>
    ))}
  </div>

  <style>
    .hero { padding: 56px 0 36px; max-width: 60ch; }
    .eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 12px;
      letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold);
      margin-bottom: 16px;
    }
    h1 {
      font-family: 'Fraunces', serif; font-weight: 900;
      font-size: clamp(36px, 6vw, 60px); line-height: 1.02;
      letter-spacing: -0.02em;
    }
    h1 em { color: var(--rust); font-style: normal; }
    .sub { margin-top: 20px; font-size: 18px; color: #6a6052; }
    .stat {
      margin-top: 18px; font-family: 'JetBrains Mono', monospace; font-size: 14px;
      color: var(--teal);
    }
    .stat strong { color: var(--rust); font-size: 18px; }

    .grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px; margin-bottom: 40px;
    }
    .card {
      display: block; text-decoration: none; color: var(--ink);
      background: #fff; border: 1px solid var(--line); border-radius: 16px;
      padding: 22px; transition: 0.18s; position: relative;
      box-shadow: var(--shadow);
    }
    .card:hover { transform: translateY(-3px); border-color: var(--rust); }
    .count {
      font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700;
      color: var(--gold);
    }
    .card h2 {
      font-family: 'Fraunces', serif; font-weight: 600; font-size: 24px;
      margin: 6px 0 4px;
    }
    .card p { font-size: 14px; color: #7a6f60; }
    .go {
      display: inline-block; margin-top: 14px; font-size: 14px; font-weight: 600;
      color: var(--rust-dk);
    }
  </style>
</Base>
