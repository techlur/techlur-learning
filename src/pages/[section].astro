---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import QuestionCard from '../components/QuestionCard.astro';

export async function getStaticPaths() {
  const all = await getCollection('questions');
  const meta: Record<string, { label: string; desc: string }> = {
    backend: { label: 'Backend', desc: 'HTTP fundamentals, Node.js, NestJS, auth, and APIs.' },
    frontend: { label: 'Frontend', desc: 'JavaScript core, the browser, React, and CSS.' },
    database: { label: 'Database', desc: 'MySQL, SQL queries, modelling, and indexing.' },
    ai: { label: 'AI & LLMs', desc: 'Core concepts, RAG, calling APIs, and prompting.' },
    general: { label: 'General & HR', desc: 'Git, DSA, OOP, and behavioural rounds.' },
  };

  const ids = [...new Set(all.map((q) => q.data.section))];

  return ids.map((id) => {
    const questions = all
      .filter((q) => q.data.section === id)
      .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
    return {
      params: { section: id },
      props: { questions, meta: meta[id] ?? { label: id, desc: '' }, sectionId: id },
    };
  });
}

const { questions, meta, sectionId } = Astro.props;

const seoDescription = `${questions.length} ${meta.label.toLowerCase()} interview questions with model answers. ${meta.desc} Free prep for freshers and junior developers.`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: questions.map((q: any) => ({
    '@type': 'Question',
    name: q.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.body?.slice(0, 500) || meta.desc,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://learn.techlursoftware.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: meta.label,
      item: `https://learn.techlursoftware.com/${sectionId}`,
    },
  ],
};
---

<Base
  title={`${meta.label} — Interview Prep`}
  description={seoDescription}
  canonicalPath={`/${sectionId}`}
  jsonLd={[faqSchema, breadcrumbSchema]}
>
  <section class="head">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">{meta.label}</li>
      </ol>
    </nav>
    <h1>{meta.label}</h1>
    <p class="desc">{meta.desc}</p>
    <div class="tools">
      <button id="expand" aria-label="Expand all questions">Expand all</button>
      <button id="collapse" aria-label="Collapse all questions">Collapse all</button>
      <span class="n">{questions.length} questions</span>
    </div>
  </section>

  <div class="list">
    {questions.map((entry) => <QuestionCard entry={entry} />)}
  </div>

  <script is:inline>
    document.getElementById('expand')?.addEventListener('click', () =>
      document.querySelectorAll('details.qa').forEach((d) => (d.open = true))
    );
    document.getElementById('collapse')?.addEventListener('click', () =>
      document.querySelectorAll('details.qa').forEach((d) => (d.open = false))
    );
  </script>

  <style>
    .head { padding: 40px 0 24px; }
    @media (min-width: 768px) { .head { padding: 50px 0 28px; } }
    @media (min-width: 1024px) { .head { padding: 70px 0 32px; } }

    /* Breadcrumb */
    .breadcrumb ol {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 0;
      margin: 0 0 12px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 13px;
    }
    .breadcrumb li {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .breadcrumb li + li::before {
      content: '/';
      color: var(--color-gray-400);
    }
    .breadcrumb a {
      text-decoration: none;
      color: var(--color-primary);
      font-weight: 500;
      transition: color 0.15s;
    }
    .breadcrumb a:hover {
      color: var(--color-accent-dark);
    }
    .breadcrumb li[aria-current="page"] {
      color: var(--color-gray-500);
    }

    h1 {
      font-weight: 700;
      font-size: clamp(30px, 5vw, 46px);
      letter-spacing: -0.02em;
      margin-top: 8px;
      color: var(--color-gray);
    }
    .desc {
      color: var(--color-gray-400);
      margin-top: 6px;
      max-width: 60ch;
    }

    .tools {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 22px;
    }
    .tools button {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      background: #fff;
      border: 1px solid var(--color-border);
      color: var(--color-gray-500);
      padding: 8px 16px;
      border-radius: 9999px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .tools button:hover {
      background: var(--color-primary);
      color: #fff;
      border-color: var(--color-primary);
      transform: translateY(-2px);
      box-shadow: var(--shadow-green);
    }
    .tools .n {
      margin-left: auto;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      color: var(--color-gray-400);
    }

    .list {
      margin-bottom: 40px;
      max-width: 900px;
    }

    /* Dark mode */
    :global(.dark) h1 { color: #f9fafb; }
    :global(.dark) .desc { color: #9ca3af; }
    :global(.dark) .breadcrumb a { color: var(--color-primary); }
    :global(.dark) .breadcrumb a:hover { color: var(--color-accent-light); }
    :global(.dark) .breadcrumb li[aria-current="page"] { color: #9ca3af; }
    :global(.dark) .breadcrumb li + li::before { color: #6b7280; }
    :global(.dark) .tools button {
      background: var(--color-dark-card);
      border-color: var(--color-dark-border);
      color: #d1d5db;
    }
    :global(.dark) .tools button:hover {
      background: var(--color-primary);
      border-color: var(--color-primary);
      color: #fff;
    }
    :global(.dark) .tools .n { color: #9ca3af; }
  </style>
</Base>
